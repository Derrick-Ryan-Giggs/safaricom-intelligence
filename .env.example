# ─────────────────────────────────────────────────────────────
# Safaricom Intelligence — environment variables
# Copy this file to .env, fill in your values, never commit it.
# ─────────────────────────────────────────────────────────────

# ── GCP ──────────────────────────────────────────────────────
TF_VAR_project_id="your gcp project id"
TF_VAR_region="your gcp region"
TF_VAR_bq_location="your bq location"
TF_VAR_gcs_bucket_name="your gcs bucket name"
TF_VAR_credentials_file="your gcp credentials file path"

# ── Runtime (Airflow DAGs + Python scripts) ──────────────────
GCP_PROJECT_ID="your gcp project id"
GCS_BUCKET_NAME="your gcs bucket name"
GCP_CREDENTIALS_FILE="your gcp credentials file path"
BQ_DATASET_RAW="your bq dataset for raw data"
BQ_LOCATION="your bq location"

# ── dbt Cloud (used by scraper_dag to trigger dbt job) ───────
DBT_ACCOUNT_ID=your_dbt_account_id
DBT_JOB_ID=your_dbt_job_id
DBT_API_TOKEN=your_dbt_api_token

# ── Airflow ───────────────────────────────────────────────────
AIRFLOW_UID="your airflow user id (usually 50000 or 1000)"
